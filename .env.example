# Ollama API base (no trailing path). If this hostname is on the public internet,
# lock it down (Cloudflare Access, VPN-only tunnel, etc.) — Ollama has no auth by default.
OLLAMA_BASE_URL=https://ollama.tradechefpro.com
# If curl/Ollama work from your laptop but `dev-agents` on a LAN server says
# "Name or service not known", DNS for this hostname fails on that server — use LAN IP instead:
# OLLAMA_BASE_URL=http://192.168.1.xxx:11434

# Match `ollama list` / `/api/tags` name exactly (see also qwen-coder / qwen2.5-coder tags on your host).
OLLAMA_MODEL=qwen2.5-coder:32b

# Optional: comma-separated model tags always listed in the Streamlit dropdown (merge with /api/tags).
# OLLAMA_EXTRA_MODELS=gemma4:31b,qwen2.5-coder:32b

# Optional: httpx timeout in seconds for Ollama HTTP calls (default: unlimited). Large generations can exceed 10 min.
# OLLAMA_TIMEOUT=900

# Colon-separated absolute paths to git checkouts this agent may use.
# Example: /home/you/code/tradechefpro/tcp:/home/you/code/OptionsSignals
AGENT_WORKSPACES=

# LangGraph coder thread checkpoints (relative paths resolve from cwd when you launch dev-agents).
# DEV_AGENTS_CHECKPOINT_DB=.checkpoints/checkpoints.sqlite

# Extra repo-relative doc paths (comma-separated) prepended to the built-in list ingested into Coder context.
# DEV_AGENTS_CODER_DOC_PATHS=docs/HANDBOOK.md,notes/setup.md

# Coder doc injection size (defaults are large — multi‑MB). Use 0 / unlimited / none for no total cap.
# DEV_AGENTS_CODER_DOC_MAX_TOTAL=0
# DEV_AGENTS_CODER_DOC_MAX_PER_FILE=0

# Streamlit Autopilot (defaults maximize autonomy — edit here only if you want review gates back).
# DEV_AGENTS_AUTOPILOT=0           # show manual Autopilot checkboxes instead of full autopilot
# DEV_AGENTS_AUTOPILOT_LOCAL_ONLY=1   # patch workspace only; skip git branch / gh pr create
# DEV_AGENTS_AUTOPILOT_STASH=0   # fail if git working tree is dirty (disable auto git stash before PR)

# Optional: LangSmith tracing (leave unset for local-only runs).
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=dev-agents
